# --- Sync: copy current config into dotfiles/ (for updating repo after local edits)
sync_from_home() {
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)" || return 1
  mkdir -p "$script_dir/dotfiles"
  [[ -f "$HOME/.zshrc" ]] && { cp "$HOME/.zshrc" "$script_dir/dotfiles/zshrc"; echo "Copied ~/.zshrc -> dotfiles/zshrc"; }
  [[ -f "$HOME/.zprofile" ]] && { cp "$HOME/.zprofile" "$script_dir/dotfiles/zprofile"; echo "Copied ~/.zprofile -> dotfiles/zprofile"; }
  # zshenv contains secrets - do not sync; edit dotfiles/zshenv.template manually
}

# --- Main ---
main() {
  [[ "$1" == "--list" ]] && { print_inventory; exit 0; }
  [[ "$1" == "-l" ]] && { print_inventory; exit 0; }
  [[ "$1" == "--sync-from-home" ]] && { sync_from_home; exit 0; }

  local skip_brew=0
  [[ "$1" == "--skip-brew" ]] && skip_brew=1

  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)" || true
  export HOMELAB_DIR="${HOMELAB_DIR:-$SCRIPT_DIR}"

  echo "=== Terminal tools & CLI installation ==="
  install_homebrew

  echo "--- Dotfiles (.zshrc, .zshenv) ---"
  setup_dotfiles

  if [[ $skip_brew -eq 0 ]]; then
    echo "--- Installing Homebrew formulae ---"
    install_brew_formulae
    install_brew_zsh_plugins
    echo "--- Installing Homebrew casks ---"
    install_brew_casks
  fi

  echo "--- Mise (node, pnpm, python, uv) ---"
  install_mise

  echo "--- Rust ---"
  install_rust

  echo "--- Python/UV (fallback) ---"
  install_uv

  echo "--- Bun ---"
  install_bun

  echo "--- Starship ---"
  setup_starship

  echo "--- fzf-tab ---"
  install_fzf_tab

  echo "--- Navi cheats ---"
  setup_navi_cheats

  echo "--- Dotnet tools ---"
  install_dotnet_tools 2>/dev/null || true

  echo "--- Build git-fzf (optional) ---"
  build_git_fzf

  echo ""
  echo "Done. Next steps:"
  echo "  1. Add secrets to ~/.zshenv (AWS, Google, etc.) if not already present"
  echo "  2. Run: source ~/.zshenv && source ~/.zshrc"
}

main "$@"
