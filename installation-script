# --- Dotnet global tools ---
install_dotnet_tools() {
  dotnet tool install -g dotnet-ef 2>/dev/null || true
  dotnet tool install -g dotnet-counters 2>/dev/null || true
  dotnet tool install -g dotnet-dump 2>/dev/null || true
  dotnet tool install -g dotnet-trace 2>/dev/null || true
}

# --- Homelab scripts (git-fzf binary) ---
# scripts/git-fzf is a Rust binary used by fzf-tab for git checkout/switch
# Build with: cd scripts && cargo build --release
build_git_fzf() {
  local script_dir="${HOMELAB_DIR:-$HOME/Desktop/dev/guy/homelab}/scripts"
  if [[ -f "$script_dir/Cargo.toml" ]]; then
    (cd "$script_dir" && cargo build --release 2>/dev/null) || true
  fi
}

# --- Dotfiles (.zshrc, .zshenv) ---
# Copies aliases, functions, bindings, zstyle from homelab/dotfiles/
setup_dotfiles() {
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)" || script_dir="$HOME/Desktop/dev/guy/homelab"
  local homelab_dir="${HOMELAB_DIR:-$script_dir}"
  local dotfiles_dir="$script_dir/dotfiles"

  if [[ ! -d "$dotfiles_dir" ]]; then
    echo "  (no dotfiles/ dir, skipping)"
    return 0
  fi

  # .zshrc
  if [[ -f "$dotfiles_dir/zshrc" ]]; then
    [[ -f "$HOME/.zshrc" ]] && cp "$HOME/.zshrc" "$HOME/.zshrc.bak.$(date +%Y%m%d)"
    cp "$dotfiles_dir/zshrc" "$HOME/.zshrc"
    echo "  Installed ~/.zshrc (aliases, functions, bindings, zstyle)"
  fi

  # .zprofile (login shell: Python PATH, Amazon Q)
  if [[ -f "$dotfiles_dir/zprofile" ]]; then
    cp "$dotfiles_dir/zprofile" "$HOME/.zprofile"
    echo "  Installed ~/.zprofile"
  fi

  # .zshenv: set HOMELAB_DIR, create from template if missing
  if ! grep -q 'HOMELAB_DIR' "$HOME/.zshenv" 2>/dev/null; then
    local env_line="export HOMELAB_DIR=\"$homelab_dir\""
    if [[ -f "$HOME/.zshenv" ]]; then
      # Prepend HOMELAB_DIR to existing .zshenv
      echo "$env_line" | cat - "$HOME/.zshenv" > "$HOME/.zshenv.tmp" && mv "$HOME/.zshenv.tmp" "$HOME/.zshenv"
      echo "  Added HOMELAB_DIR to ~/.zshenv"
    elif [[ -f "$dotfiles_dir/zshenv.template" ]]; then
      {
        echo "$env_line"
        echo ""
        cat "$dotfiles_dir/zshenv.template"
      } > "$HOME/.zshenv"
      echo "  Created ~/.zshenv from template (add your secrets)"
    fi
  fi
}

