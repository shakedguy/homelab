#!/usr/bin/env bash
############################################################
# Terminal tools, CLI apps, and configurations
# Generated from ~/.zshrc, ~/.zshenv, homelab scripts
#
# CONFIGURATION REFERENCE (where each tool's config lives):
#   starship     ~/.config/starship/starship.toml
#   fzf          FZF_DEFAULT_OPTS, FZF_*_COMMAND (in .zshenv)
#   bat          BAT_THEME="Visual Studio Dark+" (in .zshenv)
#   zoxide       auto-init in .zshrc via eval "$(zoxide init zsh)"
#   navi         ~/Projects/navi-cheats/cheats (--path in .zshrc)
#   fzf-tab      ~/fzf-tab/fzf-tab.plugin.zsh + zstyle in .zshrc
#   uv/uvx       shell completion via eval in .zshrc (uv via mise)
#   mise         ~/.config/mise/config.toml, ~/.local/bin/mise
#   docker       ~/.docker/completions (in fpath)
#   gcloud       ~/Downloads/google-cloud-sdk or ~/.google-cloud-sdk
############################################################

set -e
set -o pipefail

# --- PATH setup (must run first) ---
path_prepend() { [[ -d "$1" ]] && export PATH="$1:$PATH"; }
path_prepend "$HOME/.local/bin"
path_prepend "/opt/homebrew/bin"
path_prepend "/opt/homebrew/opt/mysql-client/bin"
path_prepend "/opt/homebrew/opt/libpq/bin"
path_prepend "$HOME/.cargo/bin"
path_prepend "$HOME/.duckdb/cli/latest"
path_prepend "$HOME/.bun/bin"
path_prepend "$HOME/.dotnet"
path_prepend "$HOME/.dotnet/tools"
path_prepend "$HOME/Desktop/dev/guy/bin"
path_prepend "$HOME/Desktop/dev/guy/homelab/scripts"
path_prepend "$HOME/.google-cloud-sdk/bin"
path_prepend "$HOME/Library/pnpm"
path_prepend "$HOME/.antigravity/antigravity/bin"

# --- Homebrew (macOS) ---
install_homebrew() {
  if ! command -v brew &>/dev/null; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi
}

# Core CLI tools (matches actual install + shell-tooling.md)
install_brew_formulae() {
  brew install \
    bat eza fd fzf ripgrep ripgrep-all jq yq jless \
    zoxide \
    dust htop tokei \
    xh doggo \
    gnu-sed \
    minikube kubernetes-cli helm \
    tmux tree rsync \
    wget curl \
    overmind foreman \
    navi starship \
    neovim \
    mysql-client libpq \
    python@3.14 \
    go \
    bun \
    gh stripe \
    vespa-cli \
    valkey \
    jid mc \
    nginx \
    cloudflared ngrok \
    mas \
    lazysql zsh-autocomplete go-task glances mactop
}

# Zsh plugins (required for .zshrc)
install_brew_zsh_plugins() {
  brew install zsh-autosuggestions zsh-syntax-highlighting
}

# Casks (numi-cli at /usr/local/bin typically from Numi app; ngrok via brew)
install_brew_casks() {
  brew install --cask numi 2>/dev/null || true  # numi-cli for calc alias; may be from app
  brew install --cask redis-tui font-jetbrains-mono-nerd-font 2>/dev/null || true
}

# Optional / situational (k8s tools, direnv, perf)
install_brew_optional() {
  brew install dive lazydocker aws-vault atuin 2>/dev/null || true
  brew install k9s kubectx stern direnv bottom procs hyperfine coreutils 2>/dev/null || true
}

# --- Rust / Cargo ---
install_rust() {
  if ! command -v rustup &>/dev/null; then
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    source "$HOME/.cargo/env"
  fi
}

# --- Mise (node, pnpm, python, uv, watchexec) ---
install_mise() {
  if ! command -v mise &>/dev/null; then
    curl https://mise.run | sh
    export PATH="$HOME/.local/bin:$PATH"
  fi
  if [[ ! -f "$HOME/.config/mise/config.toml" ]]; then
    mkdir -p "$HOME/.config/mise"
    cat > "$HOME/.config/mise/config.toml" << 'MISE_EOF'
[tools]
node = "24"
pnpm = "10.31"
python = "3.14.2"
uv = "latest"
watchexec = "latest"
MISE_EOF
    mise install
  fi
}

# --- Python / UV (fallback if not using mise) ---
install_uv() {
  if ! command -v uv &>/dev/null; then
    if command -v mise &>/dev/null; then
      mise use -g uv@latest
    else
      curl -LsSf https://astral.sh/uv/install.sh | sh
    fi
  fi
}

# --- Bun ---
install_bun() {
  if ! command -v bun &>/dev/null; then
    curl -fsSL https://bun.sh/install | bash
  fi
}

# --- Docker completions ---
setup_docker_completions() {
  mkdir -p "$HOME/.docker/completions"
  # Docker Desktop on macOS provides these; if using colima/other, fetch manually
  if [[ -d /Applications/Docker.app ]]; then
    # Docker Desktop bundles completions
    : # no-op, Docker Desktop handles it
  fi
}

# --- fzf-tab (zsh plugin) ---
install_fzf_tab() {
  local fzf_tab_dir="$HOME/fzf-tab"
  if [[ ! -d "$fzf_tab_dir" ]]; then
    git clone https://github.com/Aloxaf/fzf-tab "$fzf_tab_dir"
  fi
}

# --- Navi cheats ---
setup_navi_cheats() {
  # .zshrc expects: navi --path ${HOME}/Projects/navi-cheats/cheats
  mkdir -p "$HOME/Projects/navi-cheats/cheats"
  # Add your cheats here or clone a repo
}

# --- Starship config ---
setup_starship() {
  mkdir -p "$HOME/.config/starship"
  if [[ ! -f "$HOME/.config/starship/starship.toml" ]]; then
    cat > "$HOME/.config/starship/starship.toml" << 'STARSHIP_EOF'
add_newline = false
command_timeout = 1000
palette = "catppuccin_mocha"
format = """[ ](mauve) $directory$character"""
right_format = """$nodejs$python$rust$dotnet$aws$kubernetes$docker_context$cmd_duration$status$hostname$time"""
[character]
success_symbol = "[➜](bold green)"
error_symbol = "[➜](bold red)"
[directory]
truncation_length = 3
truncate_to_repo = true
style = "bold lavender"
[git_branch]
symbol = " "
format = "[$symbol$branch]($style) "
style = "mauve"
[git_status]
format = "[$all_status$ahead_behind]($style) "
style = "peach"
[cmd_duration]
min_time = 500
format = "[⏱ $duration]($style) "
style = "yellow"
[status]
disabled = false
format = "[$symbol$status]($style) "
symbol = "✖ "
style = "red"
[time]
disabled = false
format = "[ $time]($style) "
time_format = "%H:%M"
style = "overlay1"
[hostname]
ssh_only = true
format = "[ $hostname]($style) "
style = "red"
[aws]
disabled = false
symbol = " "
style = "bold blue"
format = '[$symbol$profile(\($region\))]($style) '
[kubernetes]
symbol = " "
disabled = false
style = "teal"
format = '[$symbol$context( \($namespace\))]($style) '
detect_env_vars = ["KUBECONFIG"]
detect_files = ["k8s.yaml", "kustomization.yaml", "helmfile.yaml", "Chart.yaml"]
[docker_context]
disabled = false
symbol = " "
format = "[$symbol$context]($style) "
style = "sapphire"
[nodejs]
symbol = " "
style = "green"
format = "[$symbol($version)]($style) "
[python]
symbol = " "
style = "yellow"
format = "[$symbol$pyenv_prefix($version) (\\($virtualenv\\))]($style) "
detect_files = ["pyproject.toml", "requirements.txt", "Pipfile", "poetry.lock", "setup.py", "uv.lock"]
[rust]
symbol = " "
style = "peach"
format = "[$symbol($version)]($style) "
detect_files = ["Cargo.toml"]
[dotnet]
symbol = " "
style = "mauve"
format = "[$symbol($version)]($style) "
detect_files = ["*.sln", "*.csproj", "*.fsproj", "*.vbproj", "global.json"]
STARSHIP_EOF
  fi
}

